# ===========================================================================
# .env.example — Odoo Setup Script Configuration
# ===========================================================================
# Copy this file to .env and modify values as needed.
# All variables below can also be set as environment variables.
# Environment variables take precedence over this file.
# ===========================================================================

# --- Database ---------------------------------------------------------------
DB_NAME=mkli_local
DB_USER=odoo
# DB_PASSWORD=                    # Auto-generated if empty
DB_HOST=127.0.0.1
DB_PORT=5432
DB_ADMIN_USER=postgres
# DB_ADMIN_PASSWORD=              # Required for TCP connections
DB_ROLE_CAN_CREATEDB=1            # 0 or 1
DB_ROLE_SUPERUSER=0                # 0 or 1
DB_PROVISION_METHOD=auto           # auto | sudo | tcp
DB_CONNECT_RETRIES=3
DB_CONNECT_RETRY_DELAY=5

# --- Odoo -------------------------------------------------------------------
ODOO_HTTP_PORT=8069
ODOO_GEVENT_PORT=8072
ODOO_HTTP_INTERFACE=127.0.0.1
ODOO_EXPOSE_HTTP=0                # 0 or 1; when 1 and no interface is set, binds to 0.0.0.0
# ODOO_ADMIN_PASSWD=              # Auto-generated if empty
# ODOO_WEB_LOGIN=admin            # Auto-detected if empty
# ODOO_WEB_LOGIN_PASSWORD=        # Auto-generated if empty
ODOO_WEB_LOGIN_RESET=1            # 0 or 1; reset one active Odoo user to a known browser password
ODOO_PROXY_MODE=1                  # 0 or 1
ODOO_LIST_DB=0                     # 0 or 1
ODOO_WORKERS=auto                  # Integer or 'auto'
ODOO_MAX_CRON_THREADS=2
ODOO_DB_MAXCONN=64
ODOO_LIMIT_MEMORY_SOFT=auto        # Bytes or 'auto'
ODOO_LIMIT_MEMORY_HARD=auto        # Bytes or 'auto'
ODOO_LIMIT_TIME_CPU=600
ODOO_LIMIT_TIME_REAL=1200
ODOO_WITHOUT_DEMO=all
# ODOO_PACKAGE_SHA256=            # Optional: SHA256 checksum of Odoo package

# --- Restore ----------------------------------------------------------------
RESTORE_MODE=required              # required | auto | skip
RESTORE_STRATEGY=refresh           # refresh | reuse | fail
FILESTORE_STRATEGY=mirror          # mirror | merge | skip
START_AFTER_RESTORE=1              # 0 or 1
# BACKUP_INPUT=                   # Auto-detected if empty
# CUSTOM_ADDONS_DIR=              # Auto-detected if empty
# CUSTOM_ADDONS_ZIP_PATTERNS=*addons*.zip|majukendaraanlistrikindonesia-main.zip

# --- Artifacts / Packages ---------------------------------------------------
# ODOO_TAR_GZ=                    # Path to odoo*.tar.gz (auto-detected)
# ODOO_DEB_PACKAGE=               # Path to odoo*.deb (auto-detected)
# ODOO_EXE_PACKAGE=               # Path to odoo*.exe (auto-detected)
INSTALL_MODE=auto                  # auto | source | deb | exe

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO                     # DEBUG | INFO | WARN | ERROR
LOG_FORMAT=text                    # text | json
# LOG_OUTPUT=stderr                # stderr | stdout | <filepath>

# --- Resources & Behavior --------------------------------------------------
MIN_FREE_GB=20
HEALTHCHECK_TIMEOUT=120
STOP_TIMEOUT=30

# --- fetch-start Hardening --------------------------------------------------
# FETCH_START_DOWNLOAD_RETRIES=3        # Retry count for Google Drive downloads
# FETCH_START_DOWNLOAD_RETRY_DELAY=10   # Seconds between download retries
# FETCH_START_SKIP_DOWNLOAD=0           # 1=skip download if artifacts exist (idempotent re-run)
# FETCH_START_MIN_ARTIFACT_SIZE_KB=100  # Minimum artifact size to detect corruption
# FETCH_START_VALIDATE_URL=1            # 1=validate Google Drive URL format before download
# FETCH_START_CHECK_PORT=1              # 1=check if HTTP port is available before starting
# FETCH_START_REQUIRE_ODOO=1            # 1=require an Odoo installer/source artifact
# FETCH_START_REQUIRE_BACKUP=1          # 1=require a database backup so restored data is available
# FETCH_START_REQUIRE_ADDONS=1          # 1=require custom addons so restored modules are visible
# FETCH_START_MIN_RAM_GB=2              # Minimum RAM in GB for pre-flight check
# FETCH_START_AUTO_INSTALL_MODULES=1    # 1=auto-register custom modules in database
# FETCH_START_CLEAR_CACHE=0             # 1=clear all cached downloads before re-download
# FETCH_START_FORCE_REDOWNLOAD=0        # 1=force re-download even if artifacts exist
# GDOWN_TIMEOUT=0                       # Download timeout in seconds (0=no timeout)
